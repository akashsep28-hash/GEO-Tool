# ============================================================================
# The First Ranker — GEO Tool  ·  Environment configuration
# Copy this file to ".env.local" and fill in real values. NEVER commit .env.local
# ============================================================================

# --- App ---
# Public base URL of the app. Used for OAuth redirects and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (auth + database) ---
# Create a project at https://supabase.com  ->  Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key is SECRET. Server-side only. Bypasses row-level security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption ---
# Used to encrypt every user-supplied third-party API key at rest (AES-256-GCM).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=generate-a-32-byte-base64-key

# --- Default AI model (Claude) ---
# Powers blog writing, audit fix recommendations, and prompt research when the
# user has not connected their own AI key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Local LLM (Ollama / LM Studio) — optional, recommended for local/guest use ---
# If set, this local model is used for AI features (incl. the AI page auditor)
# WITHOUT needing a signed-in account or a connected key — so it also works in
# guest mode. Priority: a signed-in user's own connected model wins over this.
# Ollama example:   http://localhost:11434/v1   + model like gemma3 / llama3.1
# LM Studio example: http://localhost:1234/v1
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=

# --- Daily email (optional, for the "best topic today" digest) ---
# https://resend.com  ->  API Keys
RESEND_API_KEY=
EMAIL_FROM=GEO Tool <noreply@yourdomain.com>

# --- Cron protection (optional) ---
# A shared secret the scheduled-job endpoint checks before running.
CRON_SECRET=generate-any-random-string

# --- PageSpeed Insights (Core Web Vitals for the Page Gap SOP scorecard) ---
PAGESPEED_API_KEY=
